// Prisma schema
// Para mais informações, consulte: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lojista {
  id          Int      @id @default(autoincrement())
  nome        String
  email       String   @unique
  telefone    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  pedidos     Pedido[]
  precos      preco_lojista[]
}

model Pedido {
  id          Int           @id @default(autoincrement())
  lojistaId   Int
  status      String        @default("pendente")
  total       Decimal       @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  lojista     Lojista       @relation(fields: [lojistaId], references: [id])
  uploads     PedidoUpload[]
}

model PedidoUpload {
  id          Int      @id @default(autoincrement())
  pedidoId    Int
  arquivoUrl  String
  createdAt   DateTime @default(now())
  pedido      Pedido   @relation(fields: [pedidoId], references: [id])
}

model ListaPreco {
  id          Int            @id @default(autoincrement())
  nome        String
  descricao   String?
  ativa       Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  produtos    Produto[]
}

model Integracao {
  id          Int      @id @default(autoincrement())
  nome        String
  tipo        String
  configuracao Json?
  ativa       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Categoria {
  id          Int       @id @default(autoincrement())
  nome        String
  descricao   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  produtos    Produto[]
}

model Produto {
  id           Int            @id @default(autoincrement())
  nome         String
  descricao    String?
  sku          String         @unique
  categoriaId  Int
  listaPrecoId Int
  precoBase    Decimal        @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  categoria    Categoria      @relation(fields: [categoriaId], references: [id])
  listaPreco   ListaPreco     @relation(fields: [listaPrecoId], references: [id])
  precos       preco_lojista[]
}

model preco_lojista {
  id          Int      @id @default(autoincrement())
  lojistaId   Int
  produtoId   Int
  preco       Decimal  @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lojista     Lojista  @relation(fields: [lojistaId], references: [id])
  produto     Produto  @relation(fields: [produtoId], references: [id])

  @@unique([lojistaId, produtoId])
}