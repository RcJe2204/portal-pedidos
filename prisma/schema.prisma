generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lojista {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  telefone  String?
  status    String   @default("ativo")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pedidos       Pedido[]
  pedidosUpload PedidoUpload[] // Adicionamos esta ligação
  listaPrecos   ListaPreco[]
  integracoes   Integracao[]
  produtos      Produto[]
  precoLojista  PrecoLojista[]
}

model Pedido {
  id         String   @id @default(uuid())
  lojistaId  String
  plataforma String?
  status     String   @default("pendente")
  total      Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  lojista  Lojista       @relation(fields: [lojistaId], references: [id])
}

model PedidoUpload {
  id         String   @id @default(uuid())
  arquivoUrl String   // Nome corrigido para bater com o código
  status     String   @default("pendente")
  lojistaId  String   // Ligação direta com o lojista
  lojista    Lojista  @relation(fields: [lojistaId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ... (restante dos modelos: ListaPreco, Integracao, Categoria, Produto, PrecoLojista permanecem iguais)
model ListaPreco {
  id        String   @id @default(uuid())
  lojistaId String
  nome      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lojista Lojista @relation(fields: [lojistaId], references: [id])
}

model Integracao {
  id        String   @id @default(uuid())
  lojistaId String
  tipo      String
  token     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lojista Lojista @relation(fields: [lojistaId], references: [id])
}

model Categoria {
  id        String   @id @default(uuid())
  nome      String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  parent   Categoria? @relation("CategoriaHierarquia", fields: [parentId], references: [id])
  children Categoria[] @relation("CategoriaHierarquia")
  produtos Produto[]
}

model Produto {
  id          String   @id @default(uuid())
  lojistaId   String
  categoriaId String?
  nome        String
  descricao   String?
  sku         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lojista    Lojista       @relation(fields: [lojistaId], references: [id])
  categoria  Categoria?    @relation(fields: [categoriaId], references: [id])
  precos     PrecoLojista[]
}

model PrecoLojista {
  id         String   @id @default(uuid())
  lojistaId  String
  produtoId  String
  preco      Float
  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
  lojista Lojista @relation(fields: [lojistaId], references: [id])
  produto Produto @relation(fields: [produtoId], references: [id])
}