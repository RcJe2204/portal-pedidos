generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lojista {
  id           String   @id @default(uuid())
  nome         String
  email        String   @unique
  cnpj         String?  @unique
  senha        String
  telefone     String?
  cidade       String?
  status       String   @default("ativo")
  saldo        Float    @default(0)
  acessoPortal Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  pedidos       Pedido[]
  pedidosUpload PedidoUpload[]
  listaPrecos   ListaPreco[]
  integracoes   Integracao[]
  produtos      Produto[]
  precoLojista  PrecoLojista[]
}

model Pedido {
  id         String   @id @default(uuid())
  lojistaId  String
  plataforma String?
  status     String   @default("pendente")
  total      Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  lojista  Lojista       @relation(fields: [lojistaId], references: [id])
}

model PedidoUpload {
  id         String   @id @default(uuid())
  arquivoUrl String   
  status     String   @default("pendente")
  lojistaId  String   
  lojista    Lojista  @relation(fields: [lojistaId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Produto {
  id          String   @id @default(uuid())
  lojistaId   String
  categoriaId String?
  codigo      String   @unique // Adicionado de volta
  nome        String
  descricao   String?
  preco       Float    @default(0) // Adicionado de volta
  estoque     Int      @default(0) // Adicionado de volta
  imagemUrl   String?
  sku         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lojista    Lojista       @relation(fields: [lojistaId], references: [id])
  categoria  Categoria?    @relation(fields: [categoriaId], references: [id])
  precos     PrecoLojista[]
}

model ListaPreco {
  id        String   @id @default(uuid())
  lojistaId String
  nome      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lojista Lojista @relation(fields: [lojistaId], references: [id])
}

model Integracao {
  id        String   @id @default(uuid())
  lojistaId String
  tipo      String
  token     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lojista Lojista @relation(fields: [lojistaId], references: [id])
}

model Categoria {
  id        String   @id @default(uuid())
  nome      String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  parent   Categoria? @relation("CategoriaHierarquia", fields: [parentId], references: [id])
  children Categoria[] @relation("CategoriaHierarquia")
  produtos Produto[]
}

model PrecoLojista {
  id         String   @id @default(uuid())
  lojistaId  String
  produtoId  String
  preco      Float
  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  lojista Lojista @relation(fields: [lojistaId], references: [id])
  produto Produto @relation(fields: [produtoId], references: [id])
}