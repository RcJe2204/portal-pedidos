generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lojista {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  documento String?  @unique
  saldo     Decimal  @default(0) @db.Decimal(10, 2)
  
  blingTokens BlingToken[]
  pedidos     Pedido[]
  produtos    Produto[]
  integracoes Integracao[]
  uploads     PedidoUpload[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlingToken {
  id           String   @id @default(uuid())
  lojistaId    String
  lojista      Lojista  @relation(fields: [lojistaId], references: [id], onDelete: Cascade)
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Pedido {
  id          String   @id @default(uuid())
  lojistaId   String
  lojista     Lojista  @relation(fields: [lojistaId], references: [id])
  idBling     String?  @unique
  numero      String?
  total       Decimal  @default(0) @db.Decimal(10, 2)
  status      String   @default("PENDENTE")
  plataforma  String?  @default("Bling")
  itens       ItemPedido[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ItemPedido {
  id            String  @id @default(uuid())
  pedidoId      String
  pedido        Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produtoId     String
  produto       Produto @relation(fields: [produtoId], references: [id])
  quantidade    Int
  precoUnitario Decimal @db.Decimal(10, 2)
}

model Produto {
  id          String   @id @default(uuid())
  sku         String?  @unique
  nome        String
  descricao   String?  @db.Text
  precoBase   Decimal  @default(0) @db.Decimal(10, 2)
  estoque     Int      @default(0)
  
  lojistaId   String?
  lojista     Lojista? @relation(fields: [lojistaId], references: [id])
  itensPedido ItemPedido[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Integracao {
  id        String   @id @default(uuid())
  lojistaId String
  lojista   Lojista  @relation(fields: [lojistaId], references: [id])
  tipo      String   @default("BLING")
  config    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PedidoUpload {
  id        String   @id @default(uuid())
  lojistaId String
  lojista   Lojista  @relation(fields: [lojistaId], references: [id])
  status    String   @default("PROCESSANDO")
  arquivoUrl String
  createdAt DateTime @default(now())
}